# Fireworks AI Configuration
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Flower AI Configuration
FLOWER_MGMT_KEY=your_flower_management_key_here
FLOWER_PROJ_ID=your_flower_project_id_here

# CORS Configuration
# Comma-separated list of allowed origins for exact matches
CORS_ORIGINS=http://localhost:1420

# Optional: Regex pattern for allowed origins
# If set, this takes precedence over CORS_ORIGINS for more flexible matching
# Examples:
#   - Match any subdomain: ^https://[a-zA-Z0-9-]+\.example\.com$
#   - Match PR preview builds: ^https://myapp-pr-\d+\.onrender\.com$
#   - Match multiple patterns: ^https://(staging|preview|[a-zA-Z0-9-]+)\.example\.com$
CORS_ORIGIN_REGEX=

# Allow credentials in CORS requests (true/false)
CORS_ALLOW_CREDENTIALS=true

# Comma-separated list of allowed HTTP methods
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS

# Allowed headers (* for all, or comma-separated list)
CORS_ALLOW_HEADERS=*

# Response headers to expose to the browser (comma-separated)
CORS_EXPOSE_HEADERS=mcp-session-id

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO 